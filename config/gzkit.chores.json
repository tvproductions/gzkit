{
    "specVersion": "2.0",
    "description": "Chore registry - points to self-contained chore definitions in ops/chores/",
    "project": {
        "name": "gzkit",
        "root": ".",
        "choresDir": "ops/chores",
        "proofsPattern": "ops/chores/{slug}/proofs"
    },
    "lanes": {
        "lite": {
            "description": "Fast feedback; lint, typecheck, smoke tests (<=120s)",
            "timeoutSeconds": 120,
            "allowNetwork": false
        },
        "medium": {
            "description": "Expanded checks; full unittest, light reports; still offline",
            "timeoutSeconds": 300,
            "allowNetwork": false
        },
        "heavy": {
            "description": "Contracts/docs changed; full gates incl. coverage & security",
            "timeoutSeconds": 900,
            "allowNetwork": true
        }
    },
    "chores": [
        {
            "slug": "quality-check",
            "title": "Run full quality gates",
            "version": "2.0.0",
            "path": "ops/chores/quality-check",
            "lane": "lite"
        },
        {
            "slug": "pool-triage",
            "title": "Pool ADR Drift Triage (read-only; stopgap for ADR-pool.pool-management)",
            "version": "0.1.0",
