{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gzkit.constitution.v1",
  "title": "gzkit Constitution Schema",
  "description": "Schema for Governance Constitution documents - frontmatter and required headers.",
  "type": "object",
  "required": ["frontmatter", "headers"],
  "properties": {
    "frontmatter": {
      "type": "object",
      "description": "Required YAML frontmatter fields",
      "required": ["id", "status", "semver", "date"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^CONSTITUTION-[A-Z0-9]+-[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Constitution identifier (e.g., CONSTITUTION-KERNEL-1.0.0)"
        },
        "status": {
          "type": "string",
          "enum": ["Draft", "Review", "Ratified", "Superseded"],
          "description": "Document status"
        },
        "semver": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Semantic version"
        },
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "description": "ISO 8601 date"
        }
      },
      "additionalProperties": true
    },
    "headers": {
      "type": "array",
      "description": "Required Markdown headers (## level)",
      "items": {
        "type": "string"
      }
    }
  },
  "required_headers": [
    "Purpose",
    "Scope",
    "Principles",
    "Rules",
    "Exceptions",
    "Amendments"
  ]
}
